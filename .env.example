# Copy this file to `.env` in the project root (same folder as package.json).
# NEVER commit `.env` — it is listed in .gitignore.
#
# Vite only exposes variables that start with VITE_
# Get these values from: Firebase Console → Project settings → Your apps → Web app
# storageBucket is still in the web config string — you do NOT need to enable Cloud Storage in Firebase.

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
